  <folder name="Motivation" id="id-455cb6a729d943a0b3d04f42af11c426" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da software house" id="id-2c6c46c66bde4816aa50b2a343ce74bd"/>
    <element xsi:type="archimate:Driver" name="Acabar com a informalidade no atendimento de suporte" id="id-1cdfa64da9f747de846e5d5f4bbb0235"/>
    <element xsi:type="archimate:Goal" name="Gerenciar o ciclo de vida de cada chamado tecnico de forma digital" id="id-a87a0b5948564671b4b3d713afe85873"/>
    <element xsi:type="archimate:Goal" name="Permirtir o gerenciamento do nivel de serviço da central de atendimento" id="id-1b26bc4ad9a94abd8ab44b80079ab057"/>
    <element xsi:type="archimate:Principle" name="O desenvolvimento da solução deve usar plataformas no cost" id="id-72b0389ca1644cad8948645eba2165f6"/>
    <element xsi:type="archimate:Assessment" name="Oferecer quadros analiticos e sinteticos (relatorios, dashboards )de performance" id="id-2500afb3c2714381b8d379fb4895e5ca"/>
    <element xsi:type="archimate:Assessment" name="Desenvolver um sistema de workflow (Fluxo de trabalho) no gerenciamento de chamadas" id="id-fccfa711fc494284bd1bc34d60b224c7"/>
    <element xsi:type="archimate:Driver" name="Elevar o nível de satisfação dos clientes" id="id-3645bdb472a64983ab476c3a93b5cabe"/>
    <element xsi:type="archimate:Goal" name="Oferecer um sistema de feedback" id="id-6cb855e6eeab4861ac46d888f7eeface"/>
    <element xsi:type="archimate:Assessment" name="Conectar o sistema de BI existente ás bases de dados do sistema de suporte para que o usiario tenha auto-serviço de consultas" id="id-3420cb10ab3b49fba379823cbbe524a8"/>
    <element xsi:type="archimate:Assessment" name="Utilizar um meio de comunicação comum ao cliente (habitual)" id="id-c1035929246944baa2066dc1c2c4a3ce"/>
    <element xsi:type="archimate:Outcome" name="Meta de controlar o nível de satisfação do cliente, estatísticamente para garantir a média de nota 7 com desvio padrão 2, usando Six Sigma" id="id-24804d39a7fb40f8912e8a362dcdae83"/>
    <element xsi:type="archimate:Outcome" name="Meta de garantir 100% de registro de chaados no sistema (nenhum atendido de maneira informal)" id="id-10bdbfda084347b890b58b0143305834"/>
    <element xsi:type="archimate:Outcome" name="Meta de permitir visualizar o cumprimento do SLA (acordo de nível do serviço contratado)" id="id-6dacfbddea104820870283d75055c430"/>
    <element xsi:type="archimate:Requirement" name="Requisito de registrar novo chamado" id="id-09bc4404304444f58bdb5ce506607ecb"/>
    <element xsi:type="archimate:Requirement" name="Registrar log de ação realizada sobre um chamado" id="id-20fe1a770e5549f4a32580ce3761eaa6"/>
    <element xsi:type="archimate:Requirement" name="Registrar solução de chamada" id="id-7617045b38064e05bb59fb3f24bae22e"/>
    <element xsi:type="archimate:Constraint" name="Informar obrigatoriamente identificação do solicitante, identificação do atendente, Data e hora do inicio do atendimento, descrição do problema. O sistema deve gerar um protocolo de identificação do chamado, e associar o status &quot;Pendente&quot;. Para esse registro o cliente deve ter direito ao suporte (empresa com contrato)" id="id-6e64d778dace488abd7ef557644719ce"/>
    <element xsi:type="archimate:Meaning" name="Meaning" id="id-f2936c7ee2d447c79feb44ef260950a5"/>
    <element xsi:type="archimate:Constraint" name="Somente podem ser movimentados chamados &quot;Pendentes&quot;,Identificação do analista que tomou a ação, Descrição da ação, data e hora da operação, opcionalmente o analista pode anexar/associar uma evidência da operação feita e seu resultado" id="id-d8cd7247efca449380ed08c78f5cfc12"/>
    <element xsi:type="archimate:Constraint" name="Somente podem ser movimentados chamados &quot;Pendentes&quot;, Informar o analista solucionador, a descrição da causa do problema, Descrição da solução aplicada - O sistema vai registrar a data e hora da operação mudar o status da chamada para &quot;Encerrada&quot; e guardar a relação problema x solução em uma base de conhecimento" id="id-bba5cf231edd4e6d92406ba13375eb3d"/>
    <element xsi:type="archimate:Requirement" name="Integração da base de dados de chamados com o modelo de Data Mart do BI" id="id-8af5d71173f14a49ba0543da6b6e1b73"/>
    <element xsi:type="archimate:Constraint" name="Construção de ETL (aplicação que extrai, transforma e carrega dados) para levar o sistema transacional de chamados para o modelo de dados em formato Star Schema do Data Mart de BI" id="id-3cb011531baf4425a0015041d483d419"/>
    <element xsi:type="archimate:Requirement" name="Enviar uma pesquisa de satisfação com mensagem assim que um chamado é encerrado" id="id-e0de7aa11fd5498aa9637cb592becd7c"/>
    <element xsi:type="archimate:Requirement" name="Capturar retorna da pesquisa realizada" id="id-8784c41bd1be43a4b0c59fca4d5c9e20"/>
    <element xsi:type="archimate:Constraint" name="Enviar na pesquisa: Identificação do chamado , descrição do problema , texto padrão informando que o chamado foi encerrado e deseja-se respostas para uma pesquisa, acompanhado das perguntaas e respostas em um esquema de seleção de alternativas para o cliente escolher" id="id-1047d58681564805bc06025afd957efd"/>
    <element xsi:type="archimate:Constraint" name="Automação da coleta de respostas pelo meio de comunicação escolido, alimentando essas respostas no banco de dados transacional do sistema de suporte para uso futuro no BI" id="id-477f982cc1254a1bbd824126946f4f65"/>
  </folder>
